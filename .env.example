# Copy to .env and edit. Loaded by src/subliminal_icl/config.py (best-effort).

# Hugging Face
HF_HOME=/scratch/pb2276/.cache/huggingface
HF_TOKEN=

# Where large artifacts / activation caches live (can be a fast scratch disk)
SUBLIMINAL_ARTIFACT_ROOT=./artifacts
SUBLIMINAL_DATA_ROOT=./data

# Execution guards (see EXPERIMENT_PLAN.md §14.3 and §17)
# FAST_DEV_RUN=1 => tiny data + smoke model, completes quickly
FAST_DEV_RUN=1
# RUN_EXPENSIVE=1 must be set explicitly before any long GPU job is launched
RUN_EXPENSIVE=0
# RECOMPUTE=0 => refuse to overwrite existing artifacts
RECOMPUTE=0

# Device / dtype defaults
SUBLIMINAL_DEVICE=cuda
SUBLIMINAL_DTYPE=bfloat16
